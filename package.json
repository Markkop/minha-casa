{
  "name": "minha-casa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --dir apps/web dev",
    "check:web": "pnpm --dir apps/web check",
    "lint:web": "pnpm --dir apps/web lint",
    "test:web": "pnpm --dir apps/web test",
    "validate:web": "pnpm lint:web && pnpm check:web && pnpm test:web",
    "build": "pnpm build:web",
    "build:web": "pnpm --dir apps/web build",
    "start": "pnpm start:web",
    "start:web": "pnpm --dir apps/web preview",
    "lint": "pnpm lint:web",
    "db:setup": "bash scripts/db-setup.sh",
    "db:migrate": "bash scripts/db-migrate.sh",
    "stripe:verify-base-prices": "node scripts/verify-stripe-base-prices.mjs",
    "db:reset-credential-password": "node scripts/reset-credential-password.mjs"
  },
  "dependencies": {
    "better-auth": "^1.4.17",
    "pg": "^8.21.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreDependencies": [
        "@neondatabase/serverless"
      ]
    }
  }
}
