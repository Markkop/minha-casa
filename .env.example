# ===========================================
# Database
# ===========================================

# PostgreSQL connection string
# For production on Vercel + VPS Postgres, use sslmode=require.
DATABASE_URL="postgresql://minhacasa:CHANGE_ME@YOUR_VPS_HOST:5433/minha_casa_prod?sslmode=require"
DATABASE_SSL="true"
DATABASE_POOL_MAX="5"

# ===========================================
# Authentication (Better Auth)
# ===========================================

# Secret key for Better Auth session encryption
# Generate a secure random string (at least 32 characters)
# You can generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-here"

# Public URL used by Better Auth callbacks. In production, set this to your deployed domain.
BETTER_AUTH_URL="http://localhost:3000"

# Comma-separated list of trusted origins for authentication
# Example: "http://localhost:3000,https://yourdomain.com"
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000"

# Google OAuth (Google Cloud Console > APIs & Services > Credentials)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ===========================================
# Application URLs
# ===========================================

# Public application URL (used for share links, metadata)
# In production, set this to your domain
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Note: VERCEL_URL is automatically set by Vercel deployments

# ===========================================
# Share Links
# ===========================================

# Master password for creating share links
# Set a secure password for share link authentication
SHARE_MASTER_PASSWORD="your-secure-password-here"

# ===========================================
# External APIs
# ===========================================

# OpenAI API Key (used for parsing listings)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key"

# ScrapingAnt API Key (used to fetch listing pages from URLs in Adicionar imóvel)
# Get from https://app.scrapingant.com/
SCRAPINGANT_API_KEY="your-scrapingant-api-key"

# Google Maps API Key
# Get from https://console.cloud.google.com
# Enable the following APIs:
#   - Maps JavaScript API
#   - Geocoding API
#   - Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ===========================================
# Payment Providers - Stripe
# ===========================================

# Stripe Secret Key (server-side)
# Get from https://dashboard.stripe.com/apikeys
# Use test key (sk_test_...) for development, live key (sk_live_...) for production
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"

# Stripe Webhook Secret (for webhook signature verification)
# Get from https://dashboard.stripe.com/webhooks
# Create a webhook endpoint pointing to: https://yourdomain.com/api/webhooks/stripe
# Copy the "Signing secret" (starts with whsec_...)
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

# ===========================================
# Payment Providers - Asaas
# ===========================================

# Asaas API Key
# Get from https://www.asaas.com/ (Dashboard > Integrações > API Key)
# Use sandbox key for development, production key for production
ASAAS_API_KEY="your-asaas-api-key"

# Asaas Environment
# Set to "sandbox" for development/testing, "production" for live payments
# Defaults to "sandbox" if not set
ASAAS_ENVIRONMENT="sandbox"

# Asaas Webhook Token (for webhook verification)
# Get from https://www.asaas.com/ (Dashboard > Webhooks)
# Create a webhook pointing to: https://yourdomain.com/api/webhooks/asaas
# Copy the webhook token from the webhook configuration
ASAAS_WEBHOOK_TOKEN="your-asaas-webhook-token"
