# App Postgres (host app stack → port 5435; see infra/local/.env.local.example)
DATABASE_URL=postgresql://minhacasa:minhacasa_local_password@localhost:5435/minha_casa_local
DATABASE_SSL=false
DATABASE_POOL_MAX=10

# Better Auth — MUST match the origin you open in the browser
BETTER_AUTH_SECRET=local-better-auth-secret
BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173

# Google OAuth (add redirect URI http://localhost:5173/api/auth/callback/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Phoenix API (server-side proxy target; browser uses same-origin /api via SvelteKit)
PUBLIC_API_URL=http://localhost:4000
PHOENIX_API_URL=http://localhost:4000

# Phoenix JWT verification should fetch Better Auth keys from /api/auth/jwks.
# Host-only Svelte + Phoenix in Docker: http://host.docker.internal:5173/api/auth/jwks
# Compose svelte-web + Phoenix in Docker: http://svelte-web:5173/api/auth/jwks

# Browser Maps JS API key (Geocoding + Places + map tiles).
# Enable Maps JavaScript API, Geocoding API, and Places API in Google Cloud Console.
# Referrer restrictions must include http://localhost:5173/* (Svelte dev) and your production domain.
PUBLIC_GOOGLE_MAPS_API_KEY=
