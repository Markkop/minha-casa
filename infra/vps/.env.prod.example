# Copy to repo root as `.env.prod` on the VPS. Never commit real values.

POSTGRES_USER=minhacasa
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=minha_casa_prod
POSTGRES_PUBLIC_PORT=5433
DATABASE_POOL_MAX=10

# Phoenix backend
PHOENIX_SECRET_KEY_BASE=CHANGE_ME_GENERATED_WITH_mix_phx_gen_secret
INTERNAL_API_SECRET=CHANGE_ME_SHARED_WITH_NEXT_SERVER

# Existing approved external services
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
SCRAPINGANT_API_KEY=
BRAVE_SEARCH_API_KEY=
GOOGLE_MAPS_SERVER_API_KEY=

# MinIO object storage
MINIO_ACCESS_KEY=minhacasa
MINIO_SECRET_KEY=CHANGE_ME_STRONG_MINIO_PASSWORD
MINIO_BUCKET=minha-casa-ai

# Meta WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
APP_PUBLIC_URL=https://your-app-domain.example.com
ASSISTANT_LLM_ENABLED=true

# Hermes Agent API server for /analise. Use a strong random value for HERMES_API_KEY.
HERMES_API_URL=http://hermes-agent:8642
HERMES_API_KEY=CHANGE_ME_STRONG_HERMES_API_KEY
HERMES_ANALYSIS_TIMEOUT_MS=1800000
HERMES_INFERENCE_PROVIDER=custom
HERMES_INFERENCE_MODEL=gpt-5.4-mini
HERMES_CUSTOM_BASE_URL=https://api.openai.com/v1
PROPERTY_ANALYSIS_ENGINE=hermes

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Langfuse (self-hosted observability + prompts)
# UI: https://langfuse.casas.markkop.dev — see infra/vps/LANGFUSE.md
LANGFUSE_NEXTAUTH_URL=https://langfuse.casas.markkop.dev
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME_openssl_rand_base64_32
LANGFUSE_SALT=CHANGE_ME_openssl_rand_base64_32
LANGFUSE_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32
# Use hex-only passwords (openssl rand -hex 16) — base64 may break ClickHouse URLs
LANGFUSE_CLICKHOUSE_PASSWORD=CHANGE_ME_openssl_rand_hex_16
LANGFUSE_REDIS_PASSWORD=CHANGE_ME_openssl_rand_hex_16
LANGFUSE_S3_BUCKET=langfuse-events
LANGFUSE_INIT_ORG_ID=minha-casa-prod-org
LANGFUSE_INIT_PROJECT_ID=minha-casa-prod-project
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-minha-casa-prod
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-minha-casa-prod
LANGFUSE_INIT_USER_EMAIL=me@markkop.dev
LANGFUSE_INIT_USER_PASSWORD=CHANGE_ME_before_first_boot
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=pk-lf-minha-casa-prod
LANGFUSE_SECRET_KEY=sk-lf-minha-casa-prod
LANGFUSE_ENABLED=false
LANGFUSE_ENV=production
LANGFUSE_PROMPT_LABEL=production

# Caddy / public hostnames for the shared /docker/caddy stack
API_HOSTNAME=api.casas.example.com
MINIO_HOSTNAME=s3.casas.example.com
MINIO_CONSOLE_HOSTNAME=minio.casas.example.com
LANGFUSE_HOSTNAME=langfuse.casas.markkop.dev

# Vercel DATABASE_URL format (no sslmode in URL — set DATABASE_SSL=true in Vercel):
# postgresql://minhacasa:CHANGE_ME_STRONG_PASSWORD@YOUR_VPS_HOST:5433/minha_casa_prod
