# Copy to repo root as `.env.prod` on the VPS. Never commit real values.

POSTGRES_USER=minhacasa
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=minha_casa_prod
POSTGRES_PUBLIC_PORT=5433
DATABASE_POOL_MAX=10

# Phoenix backend
PHOENIX_SECRET_KEY_BASE=CHANGE_ME_GENERATED_WITH_mix_phx_gen_secret
INTERNAL_API_SECRET=CHANGE_ME_SHARED_WITH_NEXT_SERVER

# Existing approved external services
OPENAI_API_KEY=
SCRAPINGANT_API_KEY=

# MinIO object storage
MINIO_ACCESS_KEY=minhacasa
MINIO_SECRET_KEY=CHANGE_ME_STRONG_MINIO_PASSWORD
MINIO_BUCKET=minha-casa-ai

# Meta WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Caddy / public hostnames for the shared /docker/caddy stack
API_HOSTNAME=api.casas.example.com
MINIO_HOSTNAME=s3.casas.example.com
MINIO_CONSOLE_HOSTNAME=minio.casas.example.com

# Vercel DATABASE_URL format (no sslmode in URL — set DATABASE_SSL=true in Vercel):
# postgresql://minhacasa:CHANGE_ME_STRONG_PASSWORD@YOUR_VPS_HOST:5433/minha_casa_prod
