POSTGRES_USER=minhacasa
POSTGRES_PASSWORD=minhacasa_local_password
POSTGRES_DB=minha_casa_local
POSTGRES_PUBLIC_PORT=5434
APP_POSTGRES_PUBLIC_PORT=5435
DATABASE_URL=postgresql://minhacasa:minhacasa_local_password@postgres:5432/minha_casa_local
# Host `pnpm dev` uses Postgres on 5434 (infra/local/docker-compose.db.yml).
BACKEND_DATABASE_URL=postgresql://minhacasa:minhacasa_local_password@host.docker.internal:5434/minha_casa_local
DATABASE_SSL=false
DATABASE_POOL_MAX=10
PHOENIX_SECRET_KEY_BASE=local-secret-key-base-local-secret-key-base-local-secret-key-base-local-secret-key-base
INTERNAL_API_SECRET=local-internal-api-secret
BACKEND_API_URL=http://localhost:4000
INTERNAL_BACKEND_URL=http://phoenix-api:4000
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minhacasa
MINIO_SECRET_KEY=minhacasa_local_password
MINIO_BUCKET=minha-casa-ai
MINIO_PUBLIC_PORT=9000
MINIO_CONSOLE_PUBLIC_PORT=9001
PHOENIX_PUBLIC_PORT=4000
NEXT_PUBLIC_PORT=3000
# Required for Hermes inference (custom provider → OpenAI). Same key as Phoenix.
OPENAI_API_KEY=
SCRAPINGANT_API_KEY=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
APP_PUBLIC_URL=http://localhost:3000
ASSISTANT_LLM_ENABLED=true

# Hermes Agent API server for /analise (loaded via docker-compose env_file: .env.local).
# Copy this file to infra/local/.env.local. Compose defaults also apply if keys are missing.
HERMES_API_URL=http://hermes-agent:8642
HERMES_API_KEY=local-hermes-api-key
HERMES_ANALYSIS_TIMEOUT_MS=1800000
HERMES_INFERENCE_PROVIDER=custom
HERMES_INFERENCE_MODEL=gpt-5.4-mini
HERMES_CUSTOM_BASE_URL=https://api.openai.com/v1
PROPERTY_ANALYSIS_ENGINE=hermes

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
