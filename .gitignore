# dependencies
/node_modules
**/node_modules
/backend/deps
/backend/_build
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
**/.svelte-kit
/out/

# production
/build

# misc
.DS_Store
*.pem

