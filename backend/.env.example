# HTTP
PORT=4000
SECRET_KEY_BASE=CHANGE_ME_GENERATED_WITH_mix_phx_gen_secret
INTERNAL_API_SECRET=change-me-internal-api-secret

# Database
DATABASE_URL=postgresql://minhacasa:minhacasa_local_password@postgres:5432/minha_casa_local
DATABASE_SSL=false
DATABASE_POOL_MAX=10

# Existing approved external services
OPENAI_API_KEY=
# OpenAI model for parsing, property analysis, assistant, saved links
OPENAI_MODEL=gpt-5.4-mini
# low | medium | high | xhigh — override per call site in code where needed
OPENAI_REASONING_EFFORT=low
# Deprecated (fallback only if OPENAI_MODEL unset):
# PROPERTY_AGENT_CHAT_MODEL=gpt-5.4-mini
# PROPERTY_AGENT_VISION_MODEL=gpt-5.4-mini
PROPERTY_ANALYSIS_MAX_AGENT_CONCURRENCY=2
PROPERTY_ANALYSIS_MAX_SPACES=10
# Fotos no inventário (/analise): até 40 (máx. armazenadas no imóvel)
PROPERTY_ANALYSIS_MAX_IMAGES=40
PROPERTY_ANALYSIS_PHOTO_CONCURRENCY=4
PROPERTY_ANALYSIS_ENGINE=legacy
HERMES_API_URL=http://hermes-agent:8642
HERMES_API_KEY=
HERMES_ANALYSIS_TIMEOUT_MS=1800000
HERMES_INFERENCE_PROVIDER=custom
HERMES_INFERENCE_MODEL=gpt-5.4-mini
HERMES_CUSTOM_BASE_URL=https://api.openai.com/v1
SCRAPINGANT_API_KEY=
BRAVE_SEARCH_API_KEY=

# Geocoding + Places Nearby (/analise). Falls back to PUBLIC_GOOGLE_MAPS_API_KEY.
GOOGLE_MAPS_SERVER_API_KEY=

# Local/VPS object storage
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=minha-casa-ai
MINIO_ACCESS_KEY=minhacasa
MINIO_SECRET_KEY=minhacasa_local_password

# Meta WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
